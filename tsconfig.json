{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["node"],
    "paths": {
      "@pages/*": ["./src/pages/*"],
      "@fixtures/*": ["./src/fixtures/*"],
      "@api/*": ["./src/api/*"],
      "@test-data/*": ["./test-data/*"]
    }
  },
  "include": ["tests/**/*.ts", "src/**/*.ts", "test-data/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}